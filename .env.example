# Required public API authentication token.
# Generate one with: openssl rand -hex 32
PUBLIC_API_KEY=

# Host exposure and logging.
APP_PORT=8080
LOG_LEVEL=INFO
GPU_DEVICE_ID=0

# Internal vLLM connection and PaddleOCR-VL model selection.
VLLM_API_KEY=EMPTY
VLLM_SERVER_URL=http://paddleocr-vlm-server:8118/v1
VLLM_SERVER_MODEL_NAME=PaddleOCR-VL-1.6-0.9B
VLLM_MODEL_NAME=PaddleOCR-VL-1.6-0.9B
PIPELINE_VERSION=v1.6
LAYOUT_MODEL_NAME=PP-DocLayoutV2
VL_REC_MAX_CONCURRENCY=1

# Container storage and request limits.
UPLOAD_DIR=/data/uploads
OUTPUT_DIR=/data/outputs
MAX_FILE_SIZE_MB=100
MAX_PAGES=100
DELETE_TEMP_FILES=true

# Official PaddleOCR NVIDIA GPU images.
API_BASE_IMAGE=ccr-2vdh3abv-pub.cnc.bj.baidubce.com/paddlepaddle/paddleocr-vl:latest-nvidia-gpu
VLLM_IMAGE=ccr-2vdh3abv-pub.cnc.bj.baidubce.com/paddlepaddle/paddleocr-genai-vllm-server:latest-nvidia-gpu
