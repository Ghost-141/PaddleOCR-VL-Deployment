# Required public API authentication token.
# Generate one with: openssl rand -hex 32
PUBLIC_API_KEY=

# Host exposure and logging.
APP_PORT=8080
GPU_DEVICE_ID=0

# OCR pipeline execution and upload limits.
DEVICE=gpu:0
MAX_FILE_SIZE_MB=100
MAX_PAGES=100

# Internal vLLM and model setup credentials.
VLLM_API_KEY=EMPTY
HF_TOKEN=

# Official PaddleOCR NVIDIA GPU images.
API_BASE_IMAGE=ccr-2vdh3abv-pub.cnc.bj.baidubce.com/paddlepaddle/paddleocr-vl:latest-nvidia-gpu-offline
VLLM_IMAGE=ccr-2vdh3abv-pub.cnc.bj.baidubce.com/paddlepaddle/paddleocr-genai-vllm-server:latest-nvidia-gpu-offline
